{
  "info": {
    "name": "Smart Traffic Platform",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": "http://localhost:4100/api/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"name\":\"أمين العياري\",\"email\":\"amine@exemple.tn\",\"password\":\"123456\",\"role\":\"ADMIN\"}"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": "http://localhost:4100/api/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"email\":\"amine@exemple.tn\",\"password\":\"123456\"}"
            }
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "url": "http://localhost:4100/api/auth/me",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Vehicles",
      "item": [
        {
          "name": "Create Vehicle",
          "request": {
            "method": "POST",
            "url": "http://localhost:4200/api/vehicles",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"plateNumber\":\"تونس-123-ب\",\"type\":\"تاكسي\",\"model\":\"سيارة بلدية\",\"status\":\"نشط\"}"
            }
          }
        },
        {
          "name": "Get Vehicles",
          "request": {
            "method": "GET",
            "url": "http://localhost:4200/api/vehicles",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Add Position",
          "request": {
            "method": "POST",
            "url": "http://localhost:4200/api/vehicles/1/positions",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"latitude\":36.8,\"longitude\":10.18,\"speed\":60}"
            }
          }
        },
        {
          "name": "Get Positions",
          "request": {
            "method": "GET",
            "url": "http://localhost:4200/api/vehicles/1/positions",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Traffic",
      "item": [
        {
          "name": "Create Zone",
          "request": {
            "method": "POST",
            "url": "http://localhost:4300/api/traffic/zones",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"name\":\"باب الخضراء\",\"description\":\"وسط العاصمة تونس\",\"coordinates\":\"36.806,10.171\"}"
            }
          }
        },
        {
          "name": "Get Zones",
          "request": {
            "method": "GET",
            "url": "http://localhost:4300/api/traffic/zones",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Add Measurement",
          "request": {
            "method": "POST",
            "url": "http://localhost:4300/api/traffic/zones/1/measurements",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"vehicleCount\":80,\"speedAverage\":30.0,\"density\":75.0}"
            }
          }
        }
      ]
    },
    {
      "name": "Incidents",
      "item": [
        {
          "name": "Create Incident",
          "request": {
            "method": "POST",
            "url": "http://localhost:4500/api/incidents",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"type\":\"accident\",\"description\":\"تصادم خفيف\",\"location\":\"طريق المرسى\"}"
            }
          }
        },
        {
          "name": "Get Incidents",
          "request": {
            "method": "GET",
            "url": "http://localhost:4500/api/incidents",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Update Status",
          "request": {
            "method": "PATCH",
            "url": "http://localhost:4500/api/incidents/1/status",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"status\":\"in_progress\"}"
            }
          }
        }
      ]
    },
    {
      "name": "Notifications",
      "item": [
        {
          "name": "Send Notification",
          "request": {
            "method": "POST",
            "url": "http://localhost:4400/api/notifications",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"recipientId\":1,\"title\":\"تنبيه\",\"message\":\"ازدحام كبير في باب الخضراء\"}"
            }
          }
        },
        {
          "name": "Get Notifications",
          "request": {
            "method": "GET",
            "url": "http://localhost:4400/api/notifications",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    }
  ]
}
