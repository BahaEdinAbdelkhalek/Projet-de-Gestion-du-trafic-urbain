{
  "info": {
    "name": "Smart Traffic Platform",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": "http://localhost:4100/api/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"name\":\"Admin\",\"email\":\"admin@test.com\",\"password\":\"123456\",\"role\":\"ADMIN\"}"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": "http://localhost:4100/api/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"email\":\"admin@test.com\",\"password\":\"123456\"}"
            }
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "url": "http://localhost:4100/api/auth/me",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Traffic",
      "item": [
        {
          "name": "Create Zone",
          "request": {
            "method": "POST",
            "url": "http://localhost:4300/api/traffic/zones",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"name\":\"Zone A\",\"description\":\"City center\",\"coordinates\":\"36.8,10.1\"}"
            }
          }
        },
        {
          "name": "Get Zones",
          "request": {
            "method": "GET",
            "url": "http://localhost:4300/api/traffic/zones",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Add Measurement",
          "request": {
            "method": "POST",
            "url": "http://localhost:4300/api/traffic/zones/1/measurements",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"vehicleCount\":80,\"speedAverage\":30.0,\"density\":75.0}"
            }
          }
        }
      ]
    },
    {
      "name": "Incidents",
      "item": [
        {
          "name": "Create Incident",
          "request": {
            "method": "POST",
            "url": "http://localhost:4500/api/incidents",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"type\":\"accident\",\"description\":\"Collision\",\"location\":\"Djerba road\"}"
            }
          }
        },
        {
          "name": "Get Incidents",
          "request": {
            "method": "GET",
            "url": "http://localhost:4500/api/incidents",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Update Status",
          "request": {
            "method": "PATCH",
            "url": "http://localhost:4500/api/incidents/1/status",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"status\":\"in_progress\"}"
            }
          }
        }
      ]
    },
    {
      "name": "Notifications",
      "item": [
        {
          "name": "Send Notification",
          "request": {
            "method": "POST",
            "url": "http://localhost:4400/api/notifications",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"recipientId\":1,\"title\":\"Alert\",\"message\":\"High congestion\"}"
            }
          }
        },
        {
          "name": "Get Notifications",
          "request": {
            "method": "GET",
            "url": "http://localhost:4400/api/notifications",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    }
  ]
}
